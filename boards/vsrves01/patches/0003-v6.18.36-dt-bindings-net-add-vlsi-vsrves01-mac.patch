From 0000000000000000000000000000000000000003 Mon Sep 17 00:00:00 2001
From: Sungjoon Moon <sumoon@seoulsaram.org>
Date: Tue, 23 Jun 2026 14:00:00 +0900
Subject: [PATCH 03/11] dt-bindings: net: add VLSI VSRVES01 ethernet MAC

Document the device-tree binding for the ethernet MAC found in the
VLSI VSRVES01 RISC-V SoC.  The block exposes a single 10/100/1000
Mb/s MAC with three interrupt lines (rx, tx, mdio), a single clock
input, and an integrated memory-mapped MDIO controller as a child
node.

This binding is required to silence the dtbs_check warning
"vlsi,vsrves01-mac: failed to match any schema with compatible:
['vlsi,vsrves01-mac']" emitted by the SoC dtsi added in the next
patch.

The MAC driver itself ships in drivers/net/ethernet/vlsi/vlsi-mac.c
(added later in this series).

Signed-off-by: Sungjoon Moon <sumoon@seoulsaram.org>
---
 .../devicetree/bindings/net/vlsi,vsrves01-mac.yaml | 87 ++++++++++++++++++++++
 1 file changed, 87 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/net/vlsi,vsrves01-mac.yaml

diff --git a/Documentation/devicetree/bindings/net/vlsi,vsrves01-mac.yaml b/Documentation/devicetree/bindings/net/vlsi,vsrves01-mac.yaml
new file mode 100644
--- /dev/null
+++ b/Documentation/devicetree/bindings/net/vlsi,vsrves01-mac.yaml
@@ -0,0 +1,87 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/net/vlsi,vsrves01-mac.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: VLSI VSRVES01 Ethernet MAC
+
+maintainers:
+  - Emil Renner Berthing <emil.renner.berthing@canonical.com>
+
+description: |
+  Ethernet MAC controller integrated in the VLSI VSRVES01 RISC-V SoC.
+  The MAC supports 10/100/1000 Mb/s operation with separate RX and TX
+  data memories and an integrated memory-mapped MDIO controller.
+
+  The device exposes three interrupt outputs: one for RX completion,
+  one for TX availability and one for MDIO completion.  All three
+  must be wired up; the driver currently uses the rx and tx lines
+  via separate IRQ handlers.
+
+allOf:
+  - $ref: ethernet-controller.yaml#
+
+properties:
+  compatible:
+    const: vlsi,vsrves01-mac
+
+  reg:
+    maxItems: 1
+
+  interrupts:
+    items:
+      - description: RX interrupt
+      - description: TX interrupt
+      - description: MDIO interrupt
+
+  interrupt-names:
+    items:
+      - const: rx
+      - const: tx
+      - const: mdio
+
+  clocks:
+    maxItems: 1
+    description: System / MAC clock.
+
+  max-speed: true
+  phy-handle: true
+  phy-mode: true
+  mac-address: true
+  local-mac-address: true
+
+  mdio:
+    $ref: mdio.yaml#
+    unevaluatedProperties: false
+    description: Optional memory-mapped MDIO bus child node.
+
+required:
+  - compatible
+  - reg
+  - interrupts
+  - interrupt-names
+  - clocks
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    ethernet@17000000 {
+        compatible = "vlsi,vsrves01-mac";
+        reg = <0x17000000 0x20000>;
+        clocks = <&osc>;
+        interrupts = <5>, <6>, <7>;
+        interrupt-names = "rx", "tx", "mdio";
+        max-speed = <100>;
+
+        mdio {
+            #address-cells = <1>;
+            #size-cells = <0>;
+
+            ethernet-phy@0 {
+                reg = <0>;
+            };
+        };
+    };
+...
