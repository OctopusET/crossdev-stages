# sshd_config for VSRVES01 dev image.
# WARNING: this image is for FPGA bring-up only; root has no password and
# empty-password logins are accepted.  Do not use on a network you do not
# fully control.

Port 22
AddressFamily any
ListenAddress 0.0.0.0
ListenAddress ::

PermitRootLogin yes
PermitEmptyPasswords yes
PasswordAuthentication yes
PubkeyAuthentication yes
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
UsePAM no

# Reduce noise on a slow simulator.
LoginGraceTime 2m
MaxAuthTries 6
MaxSessions 4

PrintMotd no
PrintLastLog yes
TCPKeepAlive yes

Subsystem sftp internal-sftp
