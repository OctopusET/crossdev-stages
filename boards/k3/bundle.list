# Files copied into the K3 flash bundle by `image export --board k3 --all`.
# Paths are relative to the build directory.  Anything not listed here is
# left out — keeps the kernel/u-boot/opensbi build trees (kBytes of *.c,
# *.o, *.cmd) out of the bundle.

# Boot blobs flashed by flash.sh
u-boot/FSBL.bin
u-boot/u-boot.itb
u-boot/env.bin
u-boot/bootinfo_spinor.bin
factory/FSBL.bin
factory/bootinfo_block.bin
opensbi/build/platform/generic/firmware/fw_dynamic.itb
esos.itb

# Filesystem images
esp.vfat
bootfs.ext4
rootfs.ext4

# Full single-disk image + manifest (optional, useful for SD-card writing)
gentoo-linux-k3_dev-sdcard.img.xz
gentoo-linux-k3_dev-sdcard.img.manifest.json
